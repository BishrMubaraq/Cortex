# Copy this file to .env and adjust as needed.

# Secret key used to sign JWTs. Generate a strong value in production, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-in-production-super-secret-key

# JWT signing algorithm
ALGORITHM=HS256

# Access token lifetime in minutes (24h = 1440)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Hardcoded demo user (single-user boilerplate, no database)
DEMO_USERNAME=admin
DEMO_NAME=Admin User

# Bcrypt hash of the demo user's password.
# Default hash below corresponds to the password: "password"
# Generate a new one with:
#   python -c "from passlib.context import CryptContext; print(CryptContext(schemes=['bcrypt']).hash('yourpassword'))"
DEMO_PASSWORD_HASH=$2b$12$xg4XQ2FUYi7Dy202jTcxAe8Erz4NgrjcfYpXdbtC2HenMxuveHN4a

# Comma-separated list of allowed CORS origins (Vite dev server)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- LLM providers (for the streaming /api/chat endpoint) ---
# Set at least one key. The UI model dropdown maps to a provider:
#   "claude"        -> Anthropic (needs ANTHROPIC_API_KEY)
#   "gpt-4"         -> OpenAI    (needs OPENAI_API_KEY)
#   "llama-3-local" -> not wired up yet (returns a friendly error)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Concrete model ids (override if you want a different tier)
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
OPENAI_MODEL=gpt-4o

# Generation limits
LLM_MAX_TOKENS=1024
